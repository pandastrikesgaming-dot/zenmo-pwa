{
  "expo": {
    "name": "Zenmo",
    "slug": "zenmo-pwa",
    "scheme": "zenmo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0b0b"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Zenmo",
      "shortName": "Zenmo",
      "display": "standalone",
      "startUrl": "/",
      "scope": "/",
      "themeColor": "#0b0b0b",
      "backgroundColor": "#0b0b0b"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ]
  }
}
